# ─────────────────────────────────────────────────────────────────────────────
# Product Lab — Variáveis de Ambiente
# Arquivo: /opt/product_lab/backend/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados PostgreSQL ─────────────────────────────────────────────────
# Nota: o caractere @ na senha deve ser codificado como %40
DATABASE_URL=postgresql://productlab:prdctmngr%402026@localhost:5432/product_lab

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=product-lab-secret-key-2026-change-in-production

# ── CORS — origens permitidas (separadas por vírgula) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Pool de Conexões ──────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
